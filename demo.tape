Output demo.gif

Set FontSize 14
Set Width 1400
Set Height 600
Set Theme "Dracula"
Set PlaybackSpeed 1.0

Type "./duel a.txt b.txt"
Enter
Sleep 2s

# ハンク間ジャンプ
Sleep 500ms
Type "]c"
Sleep 800ms
Type "]c"
Sleep 800ms
Type "]c"
Sleep 800ms

# 前のハンクに戻る
Type "[c"
Sleep 800ms

# 検索
Type "/"
Sleep 300ms
Type "Config"
Enter
Sleep 800ms

# 終了
Type "q"
Sleep 500ms
